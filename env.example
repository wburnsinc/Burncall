# ============================================================
# BurnCall — Environment Variables Reference
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ── Database (required) ────────────────────────────────────
# Get a free 0.5GB Postgres instance at https://neon.tech
DATABASE_URL=postgresql://user:password@host/burncall?sslmode=require

# ── Server ──────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Public URL of your deployed frontend (used for CORS + email links)
PUBLIC_APP_URL=https://your-app.vercel.app
# Public URL of this backend itself (used to build .ics calendar-download links in confirmation emails)
PUBLIC_API_URL=https://your-backend.up.railway.app

# ── Auth (required) ─────────────────────────────────────────
# Random 32+ character secret used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_RANDOM_STRING_32_CHARS_MIN

# ── Platform Admin (optional) ────────────────────────────────
# Comma-separated email addresses that get cross-tenant platform-admin access
# (see all businesses/accounts/MRR at /admin) after their next login. This is
# the ONLY way to grant platform-admin — there is no in-app promotion button,
# by design. Sign up or log in normally first, then add your email here and
# redeploy; your next login will pick it up automatically.
PLATFORM_ADMIN_EMAILS=you@yourcompany.com

# ── AI Receptionist — Anthropic Claude (required for AI features) ──
# Get a key at https://console.anthropic.com ($5 free credit on signup)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Email — Resend (optional; email features log-only until set) ───
# Get a free key (3,000 emails/mo) at https://resend.com
RESEND_API_KEY=re_REPLACE_ME
NOTIFY_FROM_EMAIL=BurnCall <notifications@yourdomain.com>

# ── SMS — Twilio (optional; SMS features log-only until set) ───────
# Get a trial account ($15 free credit) at https://twilio.com
TWILIO_ACCOUNT_SID=ACREPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_FROM_NUMBER=+15551234567

# ── Stripe ──────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Replit Runtime (auto-injected on Replit) ────────────────
REPLIT_DOMAINS=your-app.replit.app

# ── Automations (optional) ──────────────────────────────────
# How often (ms) the automation engine checks for no-reply/appointment-reminder
# triggers to fire. Default: 300000 (5 minutes). Requires the Node process to
# stay running continuously — doesn't work on serverless/sleeping deployments.
AUTOMATION_POLL_INTERVAL_MS=300000
